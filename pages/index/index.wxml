<view class="page-shell">
  <view class="entry-shell {{pageState === 'result' ? 'entry-shell-compact' : ''}}">
    <view class="entry-copy">把老板消息翻译成真实意图，并给你一条能直接发的回复。</view>
    <button class="btn-primary primary-cta" loading="{{loading}}" bindtap="chooseImage">
      {{loading ? '正在翻译老板意思...' : '上传老板聊天截图'}}
    </button>
    <view class="entry-links">
      <text class="entry-link" bindtap="openTextSheet">直接粘贴文本</text>
      <text class="entry-link" bindtap="loadDemoCase">先看示例</text>
    </view>
  </view>

  <view wx:if="{{pageState === 'analyzing'}}" class="surface loading-card">
    <view class="loading-mark"></view>
    <view class="loading-title">正在翻译老板意思...</view>
    <view class="loading-copy">先给你一条最适合直接发出的回复。</view>
  </view>

  <view wx:if="{{pageState === 'error'}}" class="surface state-card">
    <view class="state-title">截图识别不稳定，你也可以直接粘贴文本。</view>
    <view class="state-copy">{{errorMessage}}</view>
    <view class="state-actions">
      <button class="btn-secondary state-button" bindtap="chooseImage">重新上传</button>
      <button class="link-button state-link" bindtap="openTextSheet">直接粘贴文本</button>
    </view>
  </view>

  <block wx:if="{{pageState === 'result' && analysis && activeTrack}}">
    <view class="surface summary-card">
      <view class="summary-line">老板真正要的是：{{analysis.hiddenIntent}}</view>
      <view class="tag-row">
        <view wx:for="{{insightTags}}" wx:key="index" class="quiet-tag">{{item}}</view>
      </view>
    </view>

    <view class="surface reply-card">
      <view class="reply-head">
        <view>
          <view class="eyebrow">建议你直接回</view>
          <view class="reply-title">{{activeTrack.title}}</view>
        </view>
        <view class="source-meta">{{ocrMeta.sourceLabel}}</view>
      </view>

      <view class="reply-text">{{activeTrack.reply}}</view>
      <view class="reply-note">{{activeTrack.strategy}}</view>

      <button class="btn-primary reply-button" bindtap="copyActiveTrack">复制这条</button>

      <scroll-view
        class="track-tab-row"
        scroll-x
        enable-flex="true"
        show-scrollbar="false"
      >
        <view
          wx:for="{{tracks}}"
          wx:key="id"
          class="track-tab {{activeTrackId === item.id ? 'track-tab-active' : ''}}"
          data-track-id="{{item.id}}"
          bindtap="switchTrack"
        >
          <view class="track-tab-name">{{item.title}}</view>
          <view class="track-tab-copy">{{item.tagline}}</view>
        </view>
      </scroll-view>
    </view>

    <view class="result-meta">
      <text class="inline-link" bindtap="toggleEditing">
        {{editingVisible ? '收起文本' : '识别有误？修改文本'}}
      </text>
      <text wx:if="{{errorMessage}}" class="result-hint">{{errorMessage}}</text>
    </view>

    <view wx:if="{{editingVisible}}" class="surface editor-card">
      <textarea
        class="editor-textarea"
        value="{{ocrText}}"
        maxlength="-1"
        auto-height
        placeholder="把老板消息贴在这里，再重新解码。"
        bindinput="handleOcrInput"
      />
      <button class="btn-secondary editor-button" bindtap="reAnalyzeByText" loading="{{ocrLoading}}">
        {{ocrLoading ? '重新解码中...' : '重新解码'}}
      </button>
    </view>

    <view wx:if="{{teaser && !premium}}" class="teaser-row">
      <view class="teaser-copy-block">
        <view class="teaser-title">{{teaser.title}}</view>
        <view class="teaser-copy">{{teaser.copy}}</view>
      </view>
      <button class="link-button teaser-action" bindtap="unlockPremium" loading="{{premiumLoading}}">
        {{premiumLoading ? '解锁中...' : (adReady ? '看视频解锁高级包' : '直接解锁演示版高级包')}}
      </button>
    </view>

    <view wx:if="{{premium}}" class="surface premium-card">
      <view class="premium-block">
        <view class="premium-title">下一步怎么接</view>
        <view wx:for="{{premium.followUps}}" wx:key="index" class="premium-row">
          <view class="premium-dot"></view>
          <view class="premium-copy">{{item}}</view>
        </view>
      </view>

      <view class="premium-block">
        <view class="premium-title">哪些话别说</view>
        <view wx:for="{{premium.avoidPhrases}}" wx:key="index" class="premium-row">
          <view class="premium-dot premium-dot-warn"></view>
          <view class="premium-copy">{{item}}</view>
        </view>
      </view>

      <view class="premium-block">
        <view class="premium-title">升级建议</view>
        <view class="premium-highlight">{{premium.escalationTip}}</view>
      </view>
    </view>
  </block>

  <view wx:if="{{sheetVisible}}" class="sheet-mask" bindtap="closeTextSheet">
    <view class="sheet-panel" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-title">直接粘贴老板消息</view>
      <textarea
        class="sheet-textarea"
        value="{{draftText}}"
        maxlength="-1"
        auto-height
        placeholder="例如：先别解释，12 点前给我一个能发出去的版本。"
        bindinput="handleDraftInput"
      />
      <button class="btn-primary sheet-button" bindtap="submitTextSheet">开始翻译</button>
      <button class="link-button sheet-link" bindtap="closeTextSheet">取消</button>
    </view>
  </view>
</view>
